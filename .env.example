# Supabase storage buckets
NEXT_PUBLIC_PROJECT_IMAGES_BUCKET=project-images
NEXT_PUBLIC_INSIGHT_IMAGES_BUCKET=insight-images

# Public site configuration
NEXT_PUBLIC_SITE_URL=https://eryawanagung.my.id
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Server-side secrets
OPENAI_API_KEY=
